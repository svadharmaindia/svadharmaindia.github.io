<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Svadharma India — Indian Knowledge Systems</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&family=EB+Garamond:ital,wght@0,400;0,500;1,400&display=swap" rel="stylesheet" />
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --gold-deep:   #7a5a10;
    --gold-mid:    #8b6914;
    --gold-light:  #c9a96e;
    --gold-pale:   #e8d5a3;
    --cream-dark:  #f0ebe0;
    --cream:       #f5f0e6;
    --cream-light: #faf8f4;
    --ink-dark:    #2e2010;
    --ink:         #3a2e1e;
    --ink-mid:     #5c4520;
    --serif: 'Cormorant Garamond', 'Georgia', serif;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--serif);
    background: var(--cream-light);
    color: var(--ink);
    line-height: 1.7;
    font-size: 16px;
  }

  /* ── NAV ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 248, 244, 0.96);
    backdrop-filter: blur(6px);
    border-bottom: 0.5px solid rgba(201,169,110,0.3);
    padding: 14px 48px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand {
    font-size: 13px;
    letter-spacing: 0.28em;
    color: var(--gold-mid);
    font-weight: 400;
    text-transform: uppercase;
    text-decoration: none;
  }

  .nav-links {
    display: flex;
    gap: 32px;
    list-style: none;
  }

  .nav-links a {
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 0.13em;
    color: var(--ink-mid);
    font-weight: 400;
    transition: color 0.2s;
  }

  .nav-links a:hover { color: var(--gold-mid); }

  .nav-hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    cursor: pointer;
    background: none;
    border: none;
    padding: 4px;
  }

  .nav-hamburger span {
    display: block;
    width: 22px;
    height: 1px;
    background: var(--gold-mid);
  }

  /* ── HERO ── */
  .hero {
    text-align: center;
    padding: 72px 48px 60px;
    background: linear-gradient(180deg, var(--cream-light) 0%, var(--cream) 100%);
    border-bottom: 0.5px solid rgba(201,169,110,0.25);
  }

  .hero h1 {
    font-size: 48px;
    font-weight: 300;
    letter-spacing: 0.2em;
    color: var(--gold-deep);
    line-height: 1.15;
    margin-bottom: 8px;
  }

  .hero-subtitle {
    font-size: 16px;
    letter-spacing: 0.22em;
    color: var(--gold-light);
    font-weight: 300;
    font-style: italic;
    margin-bottom: 24px;
  }

  .hero-tagline {
    font-size: 19px;
    color: var(--ink-mid);
    font-style: italic;
    font-weight: 300;
    max-width: 580px;
    margin: 0 auto 36px;
    line-height: 1.9;
  }

  .cta-row {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn {
    padding: 12px 32px;
    font-family: var(--serif);
    font-size: 14px;
    letter-spacing: 0.16em;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.22s;
    text-decoration: none;
    display: inline-block;
  }

  .btn-gold {
    background: var(--gold-mid);
    color: #fdf8ec;
    border: 1px solid var(--gold-mid);
  }

  .btn-gold:hover { background: var(--gold-deep); border-color: var(--gold-deep); }

  .btn-outline {
    background: transparent;
    color: var(--gold-mid);
    border: 0.5px solid var(--gold-mid);
  }

  .btn-outline:hover { background: rgba(139,105,20,0.07); }

  /* ── ORNAMENTS ── */
  .ornament {
    text-align: center;
    color: rgba(201,169,110,0.5);
    font-size: 15px;
    letter-spacing: 0.45em;
    padding: 8px 0;
  }

  /* ── SECTIONS ── */
  section {
    padding: 64px 48px;
  }

  section.alt { background: var(--cream); }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-header h2 {
    font-size: 32px;
    font-weight: 300;
    letter-spacing: 0.15em;
    color: var(--gold-deep);
    margin-bottom: 6px;
  }

  .section-header .eyebrow {
    font-size: 14px;
    color: var(--gold-light);
    letter-spacing: 0.18em;
    font-style: italic;
  }

  /* ── ARTICLE CARDS ── */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 28px;
    max-width: 1000px;
    margin: 0 auto;
  }

  .card {
    background: var(--cream-light);
    border: 0.5px solid rgba(201,169,110,0.4);
    border-radius: 4px;
    padding: 36px 32px;
    text-align: left;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(139, 105, 20, 0.05);
  }

  .card-date {
    font-size: 13px;
    color: var(--gold-light);
    letter-spacing: 0.1em;
    font-style: italic;
    margin-bottom: 12px;
    display: block;
  }

  .card h3 {
    font-size: 22px;
    font-weight: 400;
    letter-spacing: 0.05em;
    color: var(--gold-deep);
    margin-bottom: 14px;
    line-height: 1.3;
  }

  .card p {
    font-size: 16px;
    color: var(--ink-mid);
    line-height: 1.8;
    font-weight: 300;
    margin-bottom: 22px;
    flex-grow: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 22px;
  }

  .tag {
    background: var(--cream);
    border: 0.5px solid rgba(201,169,110,0.5);
    color: var(--gold-deep);
    font-size: 11px;
    letter-spacing: 0.1em;
    padding: 4px 10px;
    border-radius: 2px;
    font-family: var(--serif);
    text-transform: uppercase;
  }

  .card-btn {
    display: inline-block;
    padding: 10px 0;
    color: var(--gold-mid);
    font-family: var(--serif);
    font-size: 14px;
    letter-spacing: 0.16em;
    cursor: pointer;
    text-decoration: none;
    border-top: 0.5px solid rgba(201,169,110,0.2);
    transition: color 0.2s;
  }

  .card-btn:hover {
    color: var(--gold-deep);
    text-decoration: underline;
  }

  /* ── ABOUT ── */
  .about-inner {
    max-width: 680px;
    margin: 0 auto;
    text-align: center;
  }

  .about-quote {
    font-size: 20px;
    line-height: 2;
    color: var(--ink-mid);
    font-style: italic;
    font-weight: 300;
    margin-bottom: 28px;
    border-left: 2px solid var(--gold-pale);
    padding-left: 28px;
    text-align: left;
  }

  .about-body {
    font-size: 17px;
    line-height: 1.95;
    color: var(--ink-mid);
    font-weight: 300;
    margin-bottom: 20px;
  }

  .about-sig {
    font-size: 15px;
    letter-spacing: 0.18em;
    color: var(--gold-mid);
    font-style: normal;
    margin-top: 28px;
    display: block;
  }

  /* ── CONTACT ── */
  .contact-inner {
    max-width: 520px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-inner p {
    font-size: 16px;
    color: var(--ink-mid);
    line-height: 1.9;
    margin-bottom: 28px;
    font-weight: 300;
  }

  .contact-links {
    display: flex;
    gap: 14px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    border: 0.5px solid var(--gold-light);
    border-radius: 2px;
    color: var(--gold-deep);
    font-size: 14px;
    letter-spacing: 0.1em;
    cursor: pointer;
    background: transparent;
    font-family: var(--serif);
    text-decoration: none;
    transition: all 0.2s;
  }

  .contact-link:hover {
    background: var(--gold-mid);
    color: #fdf8ec;
    border-color: var(--gold-mid);
  }

  /* ── FOOTER ── */
  footer {
    background: var(--ink-dark);
    color: var(--gold-light);
    text-align: center;
    padding: 36px 48px;
    font-size: 13px;
    letter-spacing: 0.14em;
  }

  footer .foot-name {
    font-size: 17px;
    letter-spacing: 0.22em;
    color: #d4b06a;
    margin-bottom: 10px;
  }

  footer .foot-sub {
    color: rgba(201,169,110,0.65);
    margin-bottom: 10px;
    font-size: 13px;
  }

  footer .foot-copy {
    color: rgba(201,169,110,0.4);
    font-size: 12px;
  }

  /* ── SVG ICON HELPERS ── */
  .icon {
    display: inline-block;
    width: 18px;
    height: 18px;
    vertical-align: middle;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── MOBILE ── */
  @media (max-width: 680px) {
    nav { padding: 14px 20px; }
    .nav-links { display: none; }
    .nav-links.open { display: flex; flex-direction: column; gap: 16px; position: absolute; top: 52px; left: 0; right: 0; background: rgba(250,248,244,0.98); padding: 24px 28px; border-bottom: 0.5px solid rgba(201,169,110,0.3); }
    .nav-hamburger { display: flex; }
    .hero { padding: 52px 20px 44px; }
    .hero h1 { font-size: 32px; }
    section { padding: 48px 20px; }
    .cards { grid-template-columns: 1fr; }
    footer { padding: 28px 20px; }
  }

  /* ── MODAL OVERLAY ── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(46, 32, 16, 0.55);
    align-items: center;
    justify-content: center;
    padding: 20px;
  }

  .modal-overlay.open {
    display: flex;
  }

  .modal {
    background: var(--cream-light);
    border: 0.5px solid rgba(201,169,110,0.5);
    border-radius: 6px;
    padding: 44px 40px 36px;
    width: 100%;
    max-width: 420px;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    text-align: left;
  }

  .modal-close {
    position: absolute;
    top: 16px;
    right: 18px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--gold-light);
    font-size: 22px;
    line-height: 1;
    font-family: var(--serif);
    transition: color 0.2s;
  }

  .modal-close:hover { color: var(--gold-deep); }

  .modal-title {
    font-size: 24px;
    font-weight: 300;
    letter-spacing: 0.12em;
    color: var(--gold-deep);
    margin-bottom: 4px;
  }

  .modal-sub {
    font-size: 13px;
    letter-spacing: 0.14em;
    color: var(--gold-light);
    font-style: italic;
    margin-bottom: 28px;
  }

  .field { margin-bottom: 20px; }

  .field label {
    display: block;
    font-size: 13px;
    letter-spacing: 0.14em;
    color: var(--gold-mid);
    margin-bottom: 7px;
    font-weight: 400;
    text-transform: uppercase;
  }

  .field input {
    width: 100%;
    padding: 11px 14px;
    font-family: var(--serif);
    font-size: 15px;
    color: var(--ink);
    background: var(--cream);
    border: 0.5px solid rgba(201,169,110,0.5);
    border-radius: 2px;
    outline: none;
    transition: border-color 0.2s;
  }

  .field input:focus {
    border-color: var(--gold-mid);
    background: var(--cream-light);
  }

  .modal-submit {
    width: 100%;
    padding: 13px;
    background: var(--gold-mid);
    color: #fdf8ec;
    border: none;
    border-radius: 2px;
    font-family: var(--serif);
    font-size: 15px;
    letter-spacing: 0.16em;
    cursor: pointer;
    transition: background 0.2s;
    margin-top: 4px;
  }

  .modal-submit:hover { background: var(--gold-deep); }
</style>
</head>
